{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "commonjs",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./lib/",
        "resolveJsonModule": true
    },
    "include": [
        "./src"
    ],
    "exclude": [
        "node_modules",
        "lib",
        "__tests__"
    ]
}
